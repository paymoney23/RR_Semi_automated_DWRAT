c--------------------------------------------------------------------------------------------
c413 Reach Cross-section Information
c
c    rchid   x1 y1 x2 y2...
c    rchid   reach id (same as subbasin id)
c    x       distance from the left reach bank (ft)
c            it should not be greater than bank full width in card 410 (ft)
c    y       depth from the bank full reach segment (ft)
c            it should not be greater than bank full depth in card 410 (ft)
c
c--------------------------------------------------------------------------------------------
c415 reach discharge-volume relationship
c
c    rchid   reach id
c    depth   water depth (feet)
c    area    water surface area (acres)
c    vol     water volume (ac-ft)
c    disch(1, 2, 3, ....noutflows)  outflows (cfs)
c
c	rchid	depth	area	vol	disch1	disch2	dischN
c--------------------------------------------------------------------------------------------
c417 reach operations information
c 
c    rchid       reach id (same as subbasin id)
c    StartDate   start date of reach operation when the outlet is closed (month/day/year Hour:Minute:sec)
c    EndDate     end date of reach operation when the outlet is closed (month/day/year Hour:Minute:sec)
c    Outlet_1    outlet_1 operation (1-closed, 0-open)
c    Outlet_2    outlet_2 operation (1-closed, 0-open)
c    Outlet_n    outlet_n operation (1-closed, 0-open)
c                Note: At least one outlet must be opened
c 
c	rchid	StartDate	EndDate	Outlet_1	Outlet_2	Outlet_n
c-----------------------------------------------------------------------------------------
c420 general point source information
c
c    nPtSource   number of individual point sources
c    nPtQuals    number of point source quals
c
c	nPtSource	nPtQuals
	186	0
