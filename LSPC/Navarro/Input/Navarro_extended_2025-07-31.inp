c    Snow        Output snow related parameters
c    Hydrology   Output hydrology related parameters
c    Sediment    Output sediment related parameters
c    GQUAL       Output general water quality related parameters
c    RQUAL       Output biochemical water quality related parameters
c    Custom      Output user specified parameters
c    Landuse     Output landuse summary
c                 if = 0 no output 
c                 if = 1 average annual output
c                 if = 2 yearly output
c                 if = 3 monthly output
c    Stream      Output stream summary
c                 if = 0 no output 
c                 if = 1 average annual output
c                 if = 2 yearly output
c                 if = 3 monthly output
c    WaterBudget Output water budget summary
c                 if = 0 no output 
c                 if = 1 average annual output
c                 if = 2 yearly output
c                 if = 3 monthly output
c    PointSource Output point source summary
c                 if = 0 no output 
c                 if = 1 average annual output
c                 if = 2 yearly output
c                 if = 3 monthly output
c    Threshold   Output threshold analysis summary
c                 if = 0 no output 
c                 if = 1 average monthly output
c    SUSTAIN     Output unit-area land HRU timeseries for SUSTAIN external option
c                 if = 0 no output 
c                 if = 1 HRU timeseries output with gully erosion included (AGWI=0)
c                 if = 2 HRU timeseries output with gully erosion separated (AGWI=0)
c                 if = 3 HRU timeseries output with gully erosion included (AGWI=Values)
c                 if = 4 HRU timeseries output with gully erosion separated (AGWI=Values)
c    BASEFLOW    Output edge-of-stream baseflow timeseries for SUSTAIN external option
c                 if = 0 no output 
c                 if = 1 combine IFWO & AGWO timeseries output
c                 if = 2 separate IFWO & AGWO timeseries output
c    BANKEROSION Output bank erosion timeseries for SUSTAIN external option
c                 if = 0 no output 
c                 if = 1 bank erosion plus bed scour minus deposition timeseries output
c                 if = 2 bank erosion only timeseries output
c    AquiferConc Output aquifer conc. summary
c                 if = 0 no output 
c                 if = 1 flow weighted conc.
c    RQualLink   Output aquifer conc. summary
c                 if = 0 no output 
c                 if = 1 mass weighted fractions
c    RQualHRUts  Output unit-area land HRU timeseries for SUSTAIN external option
c                 if = 0 GQUAL output 
c                 if = 1 GQUAL + RQUAL species (NOx [NO2+NO3], DIN [NOx+TAM], DRP [PO4])
c    QLOSS       Output instream flow loss timeseries for SUSTAIN external option
c                 if = 0 no output 
c                 if = 1 timeseries output
c
