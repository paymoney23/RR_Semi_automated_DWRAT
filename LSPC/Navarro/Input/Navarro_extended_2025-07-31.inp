c680 TMDL reach control (used if ncrch > 0 on card 600)
c
c    rchid         controlled reach id
c    outlet        controlled reach outlet id
c    switch_mon    monthly switch to control conc limit or reduction of pollutant from the corresponding reach (0-off, 1-on)
c
c	rchid	outlet	switch_1	switch_2	switch_3	switch_4	switch_5	switch_6	switch_7	switch_8	switch_9	switch_10	switch_11	switch_12
c--------------------------------------------------------------------------------------------
c685 TMDL reach control (used if ncrch > 0 on card 600)
c
c    rchid         controlled reach id
c    outlet        controlled reach outlet id
c    limit-flow    flow limit from the corresponding reach (cfs)
c    limit_pol     concentration limit of pollutant from the corresponding reach (mg/l or ug/l or mpn/100ml)
c
c	rchid	outlet	limit_flow	limit_qual1	limit_qual2	limit_qualn
c--------------------------------------------------------------------------------------------
c690 TMDL reach control (used if ncrch > 0 on card 600)
c
